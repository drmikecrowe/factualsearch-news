---
import BaseLayout from '../layouts/BaseLayout.astro';
import SitesTable from '../components/islands/SitesTable.svelte';
---

<BaseLayout
  title="Sites - factualSearch.news"
  description="View all news sources and bias ratings available in our curated search"
>
  <!-- Hero Section -->
  <section class="hero-gradient">
    <div class="container mx-auto px-4 py-12 md:py-16">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Our <span class="text-gradient">Source</span> Database
        </h1>
        <p class="text-lg md:text-xl text-gray-600 mb-8">
          Curated news sources with transparency ratings from Media Bias/Fact Check
        </p>
      </div>
    </div>
  </section>

  <!-- Sites Table Section -->
  <section class="bg-gray-50 py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SitesTable client:load />
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="bg-white py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="info-title">Quality Standards</h3>
            <p class="info-desc">
              Only sources with <strong>Very High</strong>, <strong>High</strong>, or <strong>Mostly Factual</strong> reporting are included.
              Satire and fake news sources are excluded entirely.
            </p>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="info-title">Weekly Updates</h3>
            <p class="info-desc">
              Our source database is refreshed weekly from the latest
              <a href="https://mediabiasfactcheck.com" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 underline">
                Media Bias/Fact Check
              </a>
              ratings to ensure accuracy.
            </p>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </div>
            <h3 class="info-title">Bias Categories</h3>
            <p class="info-desc">
              Each source is tagged with its political bias: Left, Left-Center, Center, Right-Center, Right, or Pro-Science.
              Use these to explore diverse perspectives.
            </p>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <h3 class="info-title">MBFC Link</h3>
            <p class="info-desc">
              Click any source name to view its detailed Media Bias/Fact Check profile,
              including methodology, ownership, and detailed bias analysis.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-gradient-to-r from-blue-600 to-indigo-600 py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Ready to Search?</h2>
        <p class="text-lg text-blue-100 mb-6">
          Use these verified sources to find factual news on any topic.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-blue-600 font-semibold rounded-xl hover:bg-gray-100 transition-all shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Start Searching
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-gradient {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 50%, #faf5ff 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-gradient::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .text-gradient {
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .info-card {
    background: #f8fafc;
    border-radius: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(37, 99, 235, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .info-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.12);
  }

  .info-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #eff6ff 0%, #e0e7ff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .info-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: #2563eb;
  }

  .info-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .info-desc {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.6;
  }
</style>
