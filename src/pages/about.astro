---
import BaseLayout from '../layouts/BaseLayout.astro';
import MbfcNews from '../components/islands/MbfcNews.svelte';
---

<BaseLayout
  title="About factualSearch.news"
  description="Learn about our mission to fight misinformation through curated news search"
>
  <!-- Hero Section -->
  <section class="hero-gradient">
    <div class="container mx-auto px-4 py-12 md:py-16">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Fighting <span class="text-gradient">Misinformation</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 mb-8">
          A curated search engine that helps you find factual news from credible sources
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="bg-white py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Our Mission</h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Be aware. Be informed. Combat propaganda by researching with purpose.
            Don't take a friend's word for it—verify with credible sources.
          </p>
        </div>

        <!-- Feature Cards -->
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="feature-title">Verified Sources</h3>
            <p class="feature-desc">
              Only sites with <span class="font-semibold text-green-600">Very High, High, or Mostly Factual</span> reporting ratings by Media Bias/Fact Check are included in our search results.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
            <h3 class="feature-title">Bias Transparency</h3>
            <p class="feature-desc">
              Every source is tagged with its political bias so you can understand the viewpoint and see multiple perspectives.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="feature-title">Privacy First</h3>
            <p class="feature-desc">
              We don't collect your personal information or track your searches. Your research is your business.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="bg-gray-50 py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 text-center">How It Works</h2>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 mb-8">
          <p class="text-gray-700 mb-6">
            <strong class="text-gray-900">factualSearch.news</strong> is a Google Custom Search Engine powered by the
            reporting classifications from
            <a href="https://mediabiasfactcheck.com" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 underline">
              Media Bias/Fact Check
            </a>.
          </p>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-semibold text-gray-900 mb-3">Source Criteria</h4>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  Very High, High, or Mostly Factual reporting
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  Clear bias labeling for every source
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  Regular updates to source database
                </li>
              </ul>
              <p class="text-sm text-gray-500 mt-4 italic">
                Note: Reporting levels are determined solely by Media Bias/Fact Check. We do not assign or modify these ratings—we simply use their classifications to filter our search results.
              </p>
            </div>

            <div>
              <h4 class="font-semibold text-gray-900 mb-3">Bias Categories</h4>
              <div class="flex flex-wrap gap-2">
                <span class="bias-tag bias-left">Left</span>
                <span class="bias-tag bias-left-center">Left-Center</span>
                <span class="bias-tag bias-center">Least Biased</span>
                <span class="bias-tag bias-right-center">Right-Center</span>
                <span class="bias-tag bias-right">Right</span>
                <span class="bias-tag bias-science">Pro-Science</span>
              </div>
              <p class="text-sm text-gray-500 mt-3">
                Plus grouped views: Left Leaning, Right Leaning, and Mostly Center
              </p>
            </div>
          </div>
        </div>

        <!-- Default Search Explanation -->
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-6 md:p-8 border border-blue-100">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Understanding Your Results</h3>
          <p class="text-gray-700 mb-4">
            By default, searches show <strong>"Mostly Center"</strong> results—sources with minimal bias.
            You'll see highly credible outlets like
            <a href="https://mediabiasfactcheck.com/reuters/" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 underline">Reuters</a>
            and the
            <a href="https://mediabiasfactcheck.com/associated-press/" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 underline">Associated Press</a>,
            alongside slightly biased but still factual sources like the
            <a href="https://mediabiasfactcheck.com/washington-post/" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 underline">Washington Post</a>
            and
            <a href="https://mediabiasfactcheck.com/washington-times/" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 underline">Washington Times</a>.
          </p>
          <p class="text-gray-600">
            Use the bias filter tabs after searching to explore different perspectives on any topic.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-white py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Help Spread the Word</h2>
        <p class="text-lg text-gray-600 mb-6">
          Combat misinformation by sharing this tool with friends and family.
          Help others research with purpose and make informed decisions.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Start Searching
        </a>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <MbfcNews slot="pre-footer" client:visible />
</BaseLayout>

<style>
  .hero-gradient {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 50%, #faf5ff 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-gradient::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .text-gradient {
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .feature-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(37, 99, 235, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.12);
  }

  .feature-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #eff6ff 0%, #e0e7ff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .feature-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: #2563eb;
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .feature-desc {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .bias-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .bias-left {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .bias-left-center {
    background: #e0e7ff;
    color: #3730a3;
  }

  .bias-center {
    background: #d1fae5;
    color: #047857;
  }

  .bias-right-center {
    background: #fce7f3;
    color: #be185d;
  }

  .bias-right {
    background: #fee2e2;
    color: #b91c1c;
  }

  .bias-science {
    background: #cffafe;
    color: #0e7490;
  }
</style>
