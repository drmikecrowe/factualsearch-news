{
  "name": "fns",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "deploy": "pnpm run build && bash deploy.sh",
    "start": "astro dev",
    "build": "pnpm run check && NODE_OPTIONS=--max-old-space-size=8192 astro build",
    "check": "NODE_OPTIONS=--max-old-space-size=8192 astro check && NODE_OPTIONS=--max-old-space-size=8192 svelte-check --tsconfig ./tsconfig.json",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/svelte": "^7.2.5",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.17.2",
    "fast-xml-parser": "^5.0.0",
    "svelte": "^5.51.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-svelte": "^3.15.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "svelte-check": "^4.4.0",
    "typescript": "^5.8.2"
  }
}
